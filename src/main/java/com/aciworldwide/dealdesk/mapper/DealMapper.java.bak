package com.aciworldwide.dealdesk.mapper;

import com.aciworldwide.dealdesk.dto.DealRequestDTO;
import com.aciworldwide.dealdesk.dto.DealResponseDTO;
import com.aciworldwide.dealdesk.model.Deal;
import com.aciworldwide.dealdesk.model.DealStatus;
import org.mapstruct.*;

import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.Collection;
import java.util.Set;

/**
 * MapStruct mapper for converting between Deal entities and DTOs.
 */
@Mapper(
    componentModel = "spring",
    nullValuePropertyMappingStrategy = NullValuePropertyMappingStrategy.IGNORE,
    nullValueCheckStrategy = NullValueCheckStrategy.ALWAYS,
    collectionMappingStrategy = CollectionMappingStrategy.ADDER_PREFERRED
)
public interface DealMapper {

    @Mapping(target = "id", ignore = true)
    @Mapping(target = "status", constant = "DRAFT")
    @Mapping(target = "createdAt", ignore = true)
    @Mapping(target = "updatedAt", ignore = true)
    @Mapping(target = "approvedAt", ignore = true)
    @Mapping(target = "approvedBy", ignore = true)
    @Mapping(target = "startDate", ignore = true)
    @Mapping(target = "endDate", ignore = true)
    @Mapping(target = "totalValue", ignore = true)
    @Mapping(target = "currencyCode", ignore = true)
    @Mapping(target = "components", ignore = true)
    @Mapping(target = "pricingModel", ignore = true)
    @Mapping(target = "adjustments", ignore = true)
    @Mapping(target = "tcvCalculation", ignore = true)
    @Mapping(target = "contingentRevenue", ignore = true)
    @Mapping(target = "createdBy", ignore = true)
    @Mapping(target = "updatedBy", ignore = true)
    @Mapping(target = "synced", constant = "false")
    @Mapping(target = "lastSyncAt", ignore = true)
    @Mapping(target = "syncError", ignore = true)
    @Mapping(target = "name", source = "name")
    @Mapping(target = "description", source = "description")
    @Mapping(target = "value", source = "value")
    @Mapping(target = "products", source = "products")
    @Mapping(target = "accountId", source = "accountId")
    @Mapping(target = "accountName", source = "accountName")
    @Mapping(target = "salesRepId", source = "salesRepId")
    @Mapping(target = "salesRepName", source = "salesRepName")
    @Mapping(target = "notes", source = "notes")
    @Mapping(target = "opportunityId", source = "salesforceOpportunityId")
    Deal toDeal(DealRequestDTO dealRequestDTO);
    
    @Mapping(target = "id", source = "id")
    @Mapping(target = "name", source = "name")
    @Mapping(target = "description", source = "description")
    @Mapping(target = "salesforceOpportunityId", source = "opportunityId")
    @Mapping(target = "status", source = "status")
    @Mapping(target = "value", source = "value")
    @Mapping(target = "products", source = "products")
    @Mapping(target = "accountId", source = "accountId")
    @Mapping(target = "accountName", source = "accountName")
    @Mapping(target = "salesRepId", source = "salesRepId")
    @Mapping(target = "salesRepName", source = "salesRepName")
    @Mapping(target = "createdAt", source = "createdAt")
    @Mapping(target = "updatedAt", source = "updatedAt")
    @Mapping(target = "approvedAt", source = "approvedAt")
    @Mapping(target = "approvedBy", source = "approvedBy")
    @Mapping(target = "createdBy", source = "createdBy")
    @Mapping(target = "updatedBy", source = "updatedBy")
    @Mapping(target = "synced", source = "synced")
    @Mapping(target = "lastSyncAt", source = "lastSyncAt")
    @Mapping(target = "syncError", source = "syncError")
    @Mapping(target = "notes", source = "notes")
    @Mapping(target = "syncedWithSalesforce", source = "synced")
    @Mapping(target = "lastSyncedAt", source = "lastSyncAt")
    @Mapping(target = "lastSyncStatus", expression = "java(deal.getSyncError() == null ? \"Success\" : \"Failed\")")
    @Mapping(target = "lastSyncError", source = "syncError")
    @Mapping(target = "daysInCurrentStatus", expression = "java(calculateDaysInStatus(deal))")
    @Mapping(target = "requiresApproval", expression = "java(requiresApproval(deal.getStatus(), deal.getValue()))")
    @Mapping(target = "nextAction", expression = "java(determineNextAction(deal.getStatus()))")
    @Mapping(target = "availableActions", expression = "java(determineAvailableActions(deal.getStatus()))")
    DealResponseDTO toResponseDTO(Deal deal);

    Collection<DealResponseDTO> toResponseDTOList(Collection<Deal> deals);

    @AfterMapping
    default void setCalculatedFields(@MappingTarget DealResponseDTO response, Deal deal) {
        if (!deal.isSynced()) {
            response.setLastSyncStatus(null);
            response.setLastSyncedAt(null);
            response.setLastSyncError(null);
        }
    }

    default int calculateDaysInStatus(Deal deal) {
        if (deal.getUpdatedAt() == null) {
            return 0;
        }
        return (int) ChronoUnit.DAYS.between(deal.getUpdatedAt(), LocalDateTime.now());
    }

    default boolean requiresApproval(DealStatus status, java.math.BigDecimal value) {
        if (status != DealStatus.SUBMITTED || value == null) {
            return false;
        }
        return value.compareTo(new java.math.BigDecimal("100000")) >= 0;
    }

    default String determineNextAction(DealStatus status) {
        return switch (status) {
            case DRAFT -> "Submit for Approval";
            case SUBMITTED -> "Review";
            case IN_REVIEW -> "Approve/Reject";
            case APPROVED -> "Close Deal";
            case REJECTED -> "Revise and Resubmit";
            case CANCELLED -> "No Action Required";
            case CLOSED_WON, CLOSED_LOST -> "Archive";
        };
    }

    default Set<String> determineAvailableActions(DealStatus status) {
        return switch (status) {
            case DRAFT -> Set.of("submit", "edit", "delete");
            case SUBMITTED -> Set.of("review", "reject", "cancel");
            case IN_REVIEW -> Set.of("approve", "reject", "request_changes");
            case APPROVED -> Set.of("close_won", "close_lost", "cancel");
            case REJECTED -> Set.of("edit", "resubmit", "cancel");
            case CANCELLED -> Set.of("reopen");
            case CLOSED_WON, CLOSED_LOST -> Set.of("archive");
        };
    }
}